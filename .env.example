# ---- OSINT Fraud Intelligence: environment template ----
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Logging
OSINT_LOG_LEVEL=INFO
OSINT_ENV=dev                       # dev | prod

# Paths
OSINT_DATA_DIR=./data
OSINT_RAW_LOG=./data/raw/events.ndjson
OSINT_DB_PATH=./data/osint.db

# Ollama (local LLM)
OSINT_OLLAMA_HOST=http://localhost:11434
OSINT_OLLAMA_MODEL=llama3.1
OSINT_OLLAMA_TIMEOUT_S=60

# Risk thresholds
OSINT_ALERT_THRESHOLD=70            # dashboard highlights score >= this

# Telegram (Telethon) — get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=osint_session

# Scrapers
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; OSINT-Research/0.1; +contact-email)
SCRAPER_RATE_PER_MIN=20
